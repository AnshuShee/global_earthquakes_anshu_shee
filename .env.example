# Port number on which the Express.js server will run
PORT=5000

# Connection string for the MongoDB Database
MONGODB_URI=mongodb://127.0.0.1:27017/earthquakes

# Cryptographic key used to sign short-lived JWT Access Tokens (15 min)
JWT_SECRET=your_jwt_access_secret_key_here

# Cryptographic key used to sign long-lived JWT Refresh Tokens (7 days)
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# Application mode: development, production, or test
NODE_ENV=development

# Enable (true) or disable (false) verbose database and middleware debug logs
DEBUG=true
